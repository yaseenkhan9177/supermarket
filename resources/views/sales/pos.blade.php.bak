<!DOCTYPE html>
<html lang="en">

<head>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>

<body class="bg-gray-900 text-white font-sans h-screen overflow-hidden"
    x-data="posSystem()">

    <div class="flex h-full">

        <!-- Left Side: Product Grid -->
        <div class="w-2/3 flex flex-col p-4 bg-gray-900 border-r border-gray-800">

            <!-- Header -->
            <div class="flex items-center justify-between mb-4">
                <h1 class="text-2xl font-bold text-white">
                    <i class="fas fa-cash-register mr-2 text-indigo-500"></i> Counter POS
                </h1>
                <a href="/admin" class="text-gray-400 hover:text-white">
                    <i class="fas fa-home mr-1"></i> Dashboard
                </a>
            </div>

            <!-- Search Bar -->
            <div class="mb-4">
                <div class="relative">
                    <i class="fas fa-search absolute left-4 top-3.5 text-gray-400"></i>
                    <input type="text" x-model="search" @keyup.enter="searchAndAdd" placeholder="Search products by name or barcode..."
                        class="w-full bg-gray-800 text-white rounded-xl py-3 pl-12 pr-4 focus:ring-2 focus:ring-indigo-500 outline-none border border-gray-700">
                </div>
            </div>

            <!-- Category Filters -->
            <div class="flex gap-2 mb-4 overflow-x-auto pb-2">
                <button @click="categoryFilter = 'all'" :class="categoryFilter === 'all' ? 'bg-indigo-600 text-white' : 'bg-gray-800 text-gray-400'" class="px-4 py-2 rounded-full text-sm font-bold whitespace-nowrap transition hover:bg-indigo-700">
                    All Items
                </button>
                @foreach($items->unique('category')->pluck('category') as $category)
                <button @click="categoryFilter = '{{ $category }}'" :class="categoryFilter === '{{ $category }}' ? 'bg-indigo-600 text-white' : 'bg-gray-800 text-gray-400'" class="px-4 py-2 rounded-full text-sm font-bold whitespace-nowrap transition hover:bg-indigo-700">
                    {{ ucfirst($category) }}
                </button>
                @endforeach
            </div>

            <!-- Product Grid -->
            <div class="grid grid-cols-4 gap-4 overflow-y-auto pr-2 pb-20" style="max-height: calc(100vh - 220px);">
                <template x-for="product in filteredProducts" :key="product.id">
                    <div @click="addToCart(product)"
                        class="bg-white rounded-xl p-3 cursor-pointer hover:ring-2 hover:ring-indigo-500 transition relative group text-gray-900 h-40 flex flex-col justify-between">

                        <div class="absolute top-2 right-2 bg-gray-100 text-gray-500 text-[10px] font-bold px-1.5 py-0.5 rounded">
                            <span x-text="product.stock + ' left'"></span>
                        </div>

                        <div class="flex-1 flex items-center justify-center">
                            <i class="fas fa-box-open text-3xl text-indigo-200"></i>
                        </div>

                        <div>
                            <h4 class="font-bold text-sm leading-tight mb-1" x-text="product.name"></h4>
                            <div class="flex justify-between items-center">
                                <span class="text-indigo-600 font-bold" x-text="'$' + parseFloat(product.price).toFixed(2)"></span>
                                <button class="w-6 h-6 rounded-full bg-gray-100 text-indigo-600 flex items-center justify-center hover:bg-indigo-600 hover:text-white transition">
                                    <i class="fas fa-plus text-xs"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </template>
            </div>
        </div>

        <!-- Right Side: Cart -->
        <div class="w-1/3 bg-white flex flex-col h-full text-gray-800">

            <!-- Cart Header -->
            <div class="p-4 border-b">
                <div class="flex justify-between items-center mb-4">
                    <h2 class="font-bold text-lg">Current Order</h2>
                    <span class="bg-indigo-100 text-indigo-700 text-xs font-bold px-2 py-1 rounded" x-text="'#' + orderNumber"></span>
                </div>

                <div class="flex items-center justify-between bg-gray-50 p-2 rounded-lg border">
                    <div class="flex items-center gap-2">
                        <div class="w-8 h-8 rounded-full bg-gray-300 flex items-center justify-center text-gray-600">
                            <i class="fas fa-user"></i>
                        </div>
                        <span class="font-bold text-sm">Walk-in Customer</span>
                    </div>
                </div>
            </div>

            <!-- Cart Items -->
            <div class="flex-1 overflow-y-auto p-4 space-y-3">

                <div x-show="cart.length === 0" class="h-full flex flex-col items-center justify-center text-gray-300">
                    <i class="fas fa-shopping-basket text-6xl mb-4 text-gray-200"></i>
                    <p class="text-gray-400 font-bold">Cart is empty</p>
                    <p class="text-xs text-gray-400">Scan or select items</p>
                </div>

                <template x-for="(item, index) in cart" :key="index">
                    <div class="flex justify-between items-center bg-gray-50 p-3 rounded-lg border hover:border-indigo-200 transition group">
                        <div class="flex-1">
                            <h4 class="font-bold text-sm text-gray-800" x-text="item.name"></h4>
                            <div class="flex items-center gap-2 mt-1">
                                <button @click="decrementQty(index)" class="w-6 h-6 bg-gray-200 rounded text-gray-600 hover:bg-red-100 hover:text-red-600">
                                    <i class="fas fa-minus text-xs"></i>
                                </button>
                                <span class="text-xs font-bold text-gray-700 px-2" x-text="item.qty"></span>
                                <button @click="incrementQty(index)" class="w-6 h-6 bg-gray-200 rounded text-gray-600 hover:bg-green-100 hover:text-green-600">
                                    <i class="fas fa-plus text-xs"></i>
                                </button>
                                <span class="text-xs text-gray-500 ml-2">×</span>
                                <span class="text-xs text-gray-500" x-text="'$' + parseFloat(item.price).toFixed(2)"></span>
                            </div>
                        </div>
                        <div class="flex items-center gap-3">
                            <span class="font-bold text-indigo-600" x-text="'$' + (item.price * item.qty).toFixed(2)"></span>
                            <button @click="removeFromCart(index)" class="text-gray-300 hover:text-red-500">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>
                    </div>
                </template>
            </div>

            <!-- Cart Totals & Actions -->
            <div class="p-4 border-t bg-gray-50">
                <div class="space-y-2 mb-4 text-sm">
                    <div class="flex justify-between text-gray-600">
                        <span>Subtotal</span>
                        <span x-text="'$' + subtotal.toFixed(2)"></span>
                    </div>
                    <div class="flex justify-between text-gray-600">
                        <span>Tax (10%)</span>
                        <span x-text="'$' + tax.toFixed(2)"></span>
                    </div>
                    <div class="flex justify-between text-indigo-600 font-bold cursor-pointer hover:underline" @click="applyDiscount">
                        <span><i class="fas fa-tag mr-1"></i> Discount</span>
                        <span x-text="'-$' + discount.toFixed(2)"></span>
                    </div>
                </div>

                <div class="flex justify-between items-center mb-4 pb-2 border-t pt-2">
                    <span class="text-xl font-bold text-gray-900">Total</span>
                    <span class="text-3xl font-bold text-gray-900" x-text="'$' + total.toFixed(2)"></span>
                </div>

                <div class="grid grid-cols-2 gap-3">
                    <button @click="clearCart" class="py-3 bg-gray-200 text-gray-700 font-bold rounded-lg hover:bg-gray-300">
                        <i class="fas fa-trash mr-2"></i> Clear
                    </button>
                    <button @click="checkout" class="py-3 bg-indigo-600 text-white font-bold rounded-lg hover:bg-indigo-700 shadow-lg hover:shadow-indigo-500/50 transition">
                        Checkout <i class="fas fa-arrow-right ml-2"></i>
                    </button>
                </div>
            </div>
        </div>

    </div>

    <script>
        function posSystem() {
            return {
                search: '',
                categoryFilter: 'all',
                discount: 0.00,
                orderNumber: Math.floor(Math.random() * 10000),

                // Products from Laravel backend
                products: {
                    !!$items - > toJson() !!
                },

                cart: [],

                get filteredProducts() {
                    return this.products.filter(p => {
                        const matchesSearch = p.name.toLowerCase().includes(this.search.toLowerCase()) ||
                            (p.barcode && p.barcode.includes(this.search));
                        const matchesCategory = this.categoryFilter === 'all' || p.category === this.categoryFilter;
                        return matchesSearch && matchesCategory && p.stock > 0;
                    });
                },

                get subtotal() {
                    return this.cart.reduce((sum, item) => sum + (parseFloat(item.price) * item.qty), 0);
                },

                get tax() {
                    return this.subtotal * 0.10;
                },

                get total() {
                    return (this.subtotal + this.tax) - this.discount;
                },

                searchAndAdd() {
                    if (this.filteredProducts.length === 1) {
                        this.addToCart(this.filteredProducts[0]);
                        this.search = '';
                    }
                },

                addToCart(product) {
                    let existing = this.cart.find(item => item.id === product.id);
                    if (existing) {
                        if (existing.qty < product.stock) {
                            existing.qty++;
                        } else {
                            Swal.fire({
                                icon: 'warning',
                                title: 'Out of Stock',
                                text: 'No more stock available',
                                toast: true,
                                position: 'top-end',
                                timer: 2000,
                                showConfirmButton: false
                            });
                        }
                    } else {
                        this.cart.push({
                            ...product,
                            qty: 1
                        });
                    }
                },

                incrementQty(index) {
                    if (this.cart[index].qty < this.cart[index].stock) {
                        this.cart[index].qty++;
                    }
                },

                decrementQty(index) {
                    if (this.cart[index].qty > 1) {
                        this.cart[index].qty--;
                    } else {
                        this.removeFromCart(index);
                    }
                },

                removeFromCart(index) {
                    this.cart.splice(index, 1);
                },

                clearCart() {
                    if (this.cart.length === 0) return;

                    Swal.fire({
                        title: 'Clear Cart?',
                        text: 'All items will be removed',
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#EF4444',
                        confirmButtonText: 'Yes, clear it'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            this.cart = [];
                            this.discount = 0;
                        }
                    });
                },

                applyDiscount() {
                    Swal.fire({
                        title: 'Apply Discount',
                        input: 'number',
                        inputLabel: 'Discount Amount ($)',
                        inputPlaceholder: '0.00',
                        showCancelButton: true,
                        inputValidator: (value) => {
                            if (!value || value < 0) {
                                return 'Please enter a valid amount!';
                            }
                            if (parseFloat(value) > this.subtotal) {
                                return 'Discount cannot exceed subtotal!';
                            }
                        }
                    }).then((result) => {
                        if (result.isConfirmed) {
                            this.discount = parseFloat(result.value);
                        }
                    });
                },

                checkout() {
                    if (this.cart.length === 0) {
                        Swal.fire({
                            icon: 'warning',
                            title: 'Cart is empty!',
                            text: 'Add items to checkout',
                            toast: true,
                            position: 'top-end',
                            timer: 2000,
                            showConfirmButton: false
                        });
                        return;
                    }

                    // Show loading
                    Swal.fire({
                        title: 'Processing...',
                        allowOutsideClick: false,
                        didOpen: () => {
                            Swal.showLoading();
                        }
                    });

                    // Send to Laravel Backend
                    fetch('/sales/store', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'X-CSRF-TOKEN': '{{ csrf_token() }}'
                            },
                            body: JSON.stringify({
                                items: this.cart,
                                total: this.total,
                                discount: this.discount
                            })
                        })
                        .then(response => response.json())
                        .then(data => {
                            if (data.success) {
                                Swal.fire({
                                    icon: 'success',
                                    title: 'Order Completed!',
                                    html: `Order <strong>${data.order_number}</strong> has been saved successfully.`,
                                    timer: 3000,
                                    showConfirmButton: true
                                });
                                this.cart = [];
                                this.discount = 0;
                                this.orderNumber = Math.floor(Math.random() * 10000);
                            } else {
                                throw new Error(data.error || 'Unknown error');
                            }
                        })
                        .catch(error => {
                            Swal.fire({
                                icon: 'error',
                                title: 'Error!',
                                text: error.message || 'Failed to complete order',
                            });
                        });
                }
            }
        }
    </script>

</body>

</html>