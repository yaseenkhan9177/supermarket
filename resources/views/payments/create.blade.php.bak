                    <!-- Desktop Save Button (Hidden on Mobile) -->
                    <button type="submit"
                        class="hidden md:flex w-full bg-gray-900 hover:bg-black text-white font-semibold py-3 rounded-lg shadow-lg justify-center items-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed transition"
