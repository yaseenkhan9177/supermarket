        </section>
    </main>

    <!-- Add Category Modal -->
    <div x-show="showCategoryModal" x-cloak class="fixed inset-0 z-50 flex items-center justify-center bg-black bg-opacity-50">
        <div class="bg-white rounded-xl shadow-2xl p-6 w-full max-w-sm mx-4 transform transition-all" @click.away="showCategoryModal = false">
            <h3 class="text-lg font-bold text-gray-800 mb-4">Add New Category</h3>
            <input type="text" x-model="newCategoryName" @keydown.enter="saveCategory" class="w-full border-gray-300 rounded-lg p-3 text-sm focus-ring mb-4" placeholder="e.g. Travel, maintenance..." autofocus>
            <div class="flex gap-2">
                <button @click="showCategoryModal = false" class="flex-1 bg-gray-100 text-gray-700 py-2.5 rounded-lg font-medium hover:bg-gray-200">Cancel</button>
                <button @click="saveCategory" :disabled="!newCategoryName" class="flex-1 bg-indigo-600 text-white py-2.5 rounded-lg font-bold hover:bg-indigo-700 disabled:opacity-50">Add</button>
            </div>
        </div>
    </div>

    <!-- Notification Toast -->
    <div x-show="toast.visible" x-cloak
        x-transition
        class="fixed top-4 right-4 z-50 bg-gray-900 text-white px-4 py-3 rounded-lg shadow-xl flex items-center gap-3">
        <i class="fa-solid fa-check-circle text-green-400"></i>
        <span x-text="toast.message" class="text-sm font-medium"></span>
    </div>

    <script>
        function expenseManager() {
            return {
                currentBalance: 0,
                selectedAccountName: '',
                sessionTotal: {
                    {
                        $sessionTotal
                    }
                },
                loading: false,
                expenses: @json($sessionExpenses),
                categories: @json(collect($expenseTypes) - > map(fn($name, $id) => ['id' => $id, 'name' => $name]) - > values()),

                showCategoryModal: false,
                newCategoryName: '',

                form: {
                    date: '{{ date("Y-m-d") }}',
                    account_id: '{{ $cashAccounts->first()['
                    id '] ?? '
                    ' }}',
                    category: '',
                    payee: '',
                    amount: '',
                    notes: ''
                },

                filters: {
                    search: '',
                    category: '',
                    session_only: true,
                    date: ''
                },

                toast: {
                    visible: false,
                    message: ''
                },

                init() {
                    this.updateBalance();

                    // Keyboard Shortcuts
                    document.addEventListener('keydown', (e) => {
                        if ((e.ctrlKey || e.metaKey) && e.key === 's') {
                            e.preventDefault();
                            this.saveExpense();
                        }
                    });
                },

                async saveCategory() {
                    if (!this.newCategoryName) return;

                    try {
                        let res = await fetch('/accounts/quick-store', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'X-CSRF-TOKEN': document.querySelector('meta[name="csrf-token"]').content,
                                'Accept': 'application/json'
                            },
                            body: JSON.stringify({
                                name: this.newCategoryName
                            })
                        });

                        let data = await res.json();

                        if (data.success) {
                            this.categories.push(data.category);
                            this.form.category = data.category.name; // Auto-select
                            this.showCategoryModal = false;
                            this.newCategoryName = '';
                            this.showToast("Category added successfully!");
                        } else {
                            alert(data.message || "Failed to add category");
                        }
                    } catch (e) {
                        console.error(e);
                        alert("Error adding category");
                    }
                },

                updateBalance() {
                    const select = document.querySelector('select[x-model="form.account_id"]');
                    const option = select.selectedOptions[0];
                    if (option) {
                        this.currentBalance = parseFloat(option.dataset.balance);
                        this.selectedAccountName = option.text.trim();
                    }
                },

                async fetchExpenses() {
                    let params = new URLSearchParams({
                        search: this.filters.search,
                        category: this.filters.category,
                        session_only: this.filters.session_only,
                        date: this.filters.date
                    });

                    try {
                        let res = await fetch(`/payments/get-expenses?${params.toString()}`);
                        let data = await res.json();
                        this.expenses = data.expenses;
                    } catch (e) {
                        console.error("Filter error:", e);
                    }
                },

                async saveExpense() {
                    if (this.loading || this.form.amount <= 0 || this.form.amount > this.currentBalance) return;

                    this.loading = true;

                    // Prepare payload
                    let formData = new FormData();
                    formData.append('payment_no', 'EXP-' + Date.now()); // Temp ID, backend handles real ID
                    formData.append('payment_date', this.form.date);
                    formData.append('payment_method', 'Cash');
                    formData.append('cash_account_id', this.form.account_id);
                    formData.append('expense_type', this.form.category);
                    formData.append('paid_to_account', this.form.payee);
                    formData.append('memo', this.form.notes);

                    // Add single item
                    formData.append('items[0][expense_head]', this.form.category);
                    formData.append('items[0][amount]', this.form.amount);
                    formData.append('items[0][note]', this.form.notes);

                    try {
                        let res = await fetch('/payments/store', {
                            method: 'POST',
                            headers: {
                                'X-CSRF-TOKEN': document.querySelector('meta[name="csrf-token"]').content,
                                'Accept': 'application/json'
                            },
                            body: formData
                        });

                        let data = await res.json();

                        if (data.success) {
                            this.showToast("Expense saved successfully!");
                            this.resetForm();

                            // Update values dynamically from response
                            this.currentBalance = parseFloat(data.payment.new_balance);
                            this.sessionTotal = parseFloat(data.payment.new_session_total);

                            // Immediately fetch updated list
                            this.fetchExpenses();

                            // Update option attribute for local consistency
                            const select = document.querySelector('select[x-model="form.account_id"]');
                            const option = select.querySelector(`option[value="${this.form.account_id}"]`);
                            if (option) option.dataset.balance = this.currentBalance;

                        } else {
                            alert(data.message || "Failed to save.");
                        }

                    } catch (error) {
                        alert("System error. Please checkout console.");
                        console.error(error);
                    } finally {
                        this.loading = false;
                    }
                },

                resetForm() {
                    this.form.category = '';
                    this.form.payee = '';
                    this.form.amount = '';
                    this.form.notes = '';
                    // Keep Date and Account same as last used
                    this.$refs.category.focus();
                },

                showToast(msg) {
                    this.toast.message = msg;
                    this.toast.visible = true;
                    setTimeout(() => this.toast.visible = false, 3000);
                },

                formatCurrency(amount) {
                    return 'PKR ' + parseFloat(amount).toLocaleString('en-US', {
                        minimumFractionDigits: 2
                    });
                },

                formatTime(dateString) {
                    return new Date(dateString).toLocaleTimeString([], {
                        hour: '2-digit',
                        minute: '2-digit'
                    });
                }
            }
        }
    </script>
</body>

</html>