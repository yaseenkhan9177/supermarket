                            <div class="text-right">
                                <p class="font-bold text-gray-900" x-text="formatCurrency(expense.amount)"></p>
                                <div class="mt-1 text-xs text-green-600 flex items-center justify-end gap-1">
                                    <i class="fa-solid fa-check-circle"></i> Saved
                                </div>
